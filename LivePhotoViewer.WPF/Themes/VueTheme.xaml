<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Vue 主题：绿色系，参考 Vue.js 官网配色 -->

    <!-- 背景色 -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#1A2B1A"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="#223D22"/>
    <SolidColorBrush x:Key="ToolbarBgBrush" Color="#2D4A2D"/>
    <SolidColorBrush x:Key="ViewerBgBrush" Color="#0D1F0D"/>

    <!-- 文字色 -->
    <SolidColorBrush x:Key="TextBrush" Color="#F0FFF0"/>
    <SolidColorBrush x:Key="SubTextBrush" Color="#A8D5BA"/>
    <SolidColorBrush x:Key="DimTextBrush" Color="#7AAF8A"/>

    <!-- 边框与交互 -->
    <SolidColorBrush x:Key="BorderBrush" Color="#3A6B3A"/>
    <SolidColorBrush x:Key="HoverBorderBrush" Color="#42B883"/>
    <SolidColorBrush x:Key="ButtonHoverBgBrush" Color="#35495E"/>
    <SolidColorBrush x:Key="OverlayBgBrush" Color="#20000000"/>

    <!-- 收藏/强调 -->
    <SolidColorBrush x:Key="FavoriteBrush" Color="#FF9500"/>
    <SolidColorBrush x:Key="LiveBadgeBrush" Color="#FF2D55"/>
    <SolidColorBrush x:Key="ToggleCheckedBgBrush" Color="#30FF9500"/>

    <!-- 缩略图区域背景 -->
    <SolidColorBrush x:Key="ThumbAreaBgBrush" Color="#1A2B1A"/>
    <SolidColorBrush x:Key="ThumbPlaceholderBgBrush" Color="#0D1F0D"/>

    <!-- 通用按钮样式 -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBgBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBgBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource ToggleCheckedBgBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource FavoriteBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
