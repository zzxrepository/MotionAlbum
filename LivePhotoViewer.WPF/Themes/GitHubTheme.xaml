<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- GitHub 主题：参考 GitHub Dark Mode -->

    <!-- 背景色 -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#0D1117"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="#161B22"/>
    <SolidColorBrush x:Key="ToolbarBgBrush" Color="#21262D"/>
    <SolidColorBrush x:Key="ViewerBgBrush" Color="#010409"/>

    <!-- 文字色 -->
    <SolidColorBrush x:Key="TextBrush" Color="#C9D1D9"/>
    <SolidColorBrush x:Key="SubTextBrush" Color="#8B949E"/>
    <SolidColorBrush x:Key="DimTextBrush" Color="#6E7681"/>

    <!-- 边框与交互 -->
    <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>
    <SolidColorBrush x:Key="HoverBorderBrush" Color="#58A6FF"/>
    <SolidColorBrush x:Key="ButtonHoverBgBrush" Color="#30363D"/>
    <SolidColorBrush x:Key="OverlayBgBrush" Color="#20000000"/>

    <!-- 收藏/强调 -->
    <SolidColorBrush x:Key="FavoriteBrush" Color="#FF9500"/>
    <SolidColorBrush x:Key="LiveBadgeBrush" Color="#FF2D55"/>
    <SolidColorBrush x:Key="ToggleCheckedBgBrush" Color="#30FF9500"/>

    <!-- 缩略图区域背景 -->
    <SolidColorBrush x:Key="ThumbAreaBgBrush" Color="#0D1117"/>
    <SolidColorBrush x:Key="ThumbPlaceholderBgBrush" Color="#010409"/>

    <!-- 通用按钮样式 -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBgBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBgBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource ToggleCheckedBgBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource FavoriteBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
