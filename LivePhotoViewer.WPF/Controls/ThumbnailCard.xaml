<UserControl x:Class="LivePhotoViewer.WPF.Controls.ThumbnailCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="260">
    <Border Background="{DynamicResource CardBgBrush}"
            CornerRadius="10"
            BorderThickness="2"
            BorderBrush="Transparent"
            x:Name="CardBorder">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Color="#30000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 图片区域 -->
            <Border Grid.Row="0"
                     Background="{DynamicResource ThumbPlaceholderBgBrush}"
                     CornerRadius="8"
                     Margin="8,8,8,4"
                     ClipToBounds="True">
                <Grid>
                    <!-- 加载动画 -->
                    <Border x:Name="LoadingOverlay"
                             Background="{DynamicResource ThumbPlaceholderBgBrush}">
                        <TextBlock Text="加载中..."
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource DimTextBrush}"
                                  FontSize="12"/>
                    </Border>

                    <Image x:Name="ThumbImage"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Visibility="Collapsed"/>

                    <!-- LIVE 角标 -->
                    <Border x:Name="LiveBadge"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Background="{DynamicResource LiveBadgeBrush}"
                             CornerRadius="8"
                             Padding="6,2"
                             Margin="6,6,0,0"
                             Visibility="Collapsed">
                        <TextBlock Text="LIVE"
                                  Foreground="White"
                                  FontSize="10"
                                  FontWeight="Bold"/>
                    </Border>

                    <!-- 收藏按钮 -->
                    <Button x:Name="FavButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="28" Height="28"
                            Margin="0,6,6,0"
                            Click="FavButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                       CornerRadius="14">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock x:Name="FavIcon"
                                  Text="☆"
                                  FontSize="16"
                                  Foreground="{DynamicResource DimTextBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- 标签区域 -->
            <WrapPanel x:Name="TagsPanel"
                      Grid.Row="1"
                      Margin="8,2,8,2"
                      Orientation="Horizontal">
                <!-- 动态填充标签 -->
            </WrapPanel>

            <!-- 文件名 -->
            <TextBlock Grid.Row="2"
                       x:Name="FileNameText"
                       TextTrimming="CharacterEllipsis"
                       TextAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource SubTextBrush}"
                       Margin="8,2,8,8"/>
        </Grid>
    </Border>
</UserControl>
